# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# --- Gradle / build outputs (backend multi-module build) ---
.gradle/
build/

# The *.jar rule above would otherwise drop the committed Gradle wrapper jar,
# which must be checked in for ./gradlew to work on a fresh clone.
!**/gradle/wrapper/gradle-wrapper.jar

# --- Claude Code local state (not for the public repo) ---
.claude/

# --- Local environment / Docker overrides (.example templates ARE tracked) ---
.env
docker-compose.override.yml
