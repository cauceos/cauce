# Normalize line endings on commit; check out with native endings by default.
* text=auto eol=lf

# Windows batch scripts require CRLF.
*.bat text eol=crlf

# The Gradle wrapper shell script must stay LF to run under POSIX shells.
gradlew text eol=lf

# Treat binaries as binary (never normalize).
*.jar binary
*.png binary
*.ico binary
