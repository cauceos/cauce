# Copy to .env and adjust as needed. The .env file is gitignored.
# docker-compose.yml reads these; all have sane defaults, so .env is optional
# for local development.

# --- PostgreSQL (docker-compose) ---
POSTGRES_USER=cauce
POSTGRES_PASSWORD=cauce_dev
POSTGRES_DB=cauce_dev
POSTGRES_PORT=5433

# --- Redis / Adminer host ports (docker-compose) ---
REDIS_PORT=6379
ADMINER_PORT=8081

# --- Spring Boot "prod" profile (application-prod.properties) ---
# Not used by docker-compose. Set these in the deployment environment.
# DATABASE_URL=jdbc:postgresql://<host>:5432/cauce
# DATABASE_USERNAME=cauce
# DATABASE_PASSWORD=<secret>
# REDIS_HOST=<host>
# REDIS_PORT=6379
# REDIS_PASSWORD=<secret>
